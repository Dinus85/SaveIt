rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Cache globale anteprime: condivisa tra tutti gli utenti, senza scadenza lato regole.
    match /post_previews/{cacheType}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Legacy per-utente (post salvati prima della cache globale).
    match /users/{userId}/post_previews/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
